{
  "manifest_version": 3,
  "name": "Upside Down",
  "version": "0.1.0",
  "description": "Your AI travels with you across the web.",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "sessions"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js", "panel/panel.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {},

  "web_accessible_resources": [
    {
      "resources": ["panel/panel.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
